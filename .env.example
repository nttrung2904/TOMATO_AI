# Flask Configuration
SECRET_KEY=your-secret-key-here-change-in-production
FLASK_ENV=development

# Gemini API Configuration
# Lấy API key miễn phí tại: https://makersuite.google.com/app/apikey
# hoặc https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# OpenWeatherMap API Configuration
# Lấy API key miễn phí tại: https://openweathermap.org/api
# Free tier: 1000 calls/day, 60 calls/minute
OPENWEATHER_API_KEY=your-openweather-api-key-here

# Model Cache Configuration
# Số lượng model tối đa được giữ trong bộ nhớ (RAM)
# Giảm nếu gặp lỗi Out of Memory
MAX_LOADED_MODELS=2

# Prediction Confidence Thresholds
# Ngưỡng confidence tối thiểu để chấp nhận kết quả dự đoán
MIN_MODEL_CONF=0.85

# Similarity Check Thresholds
# Ngưỡng tương đồng với mẫu dương tính (tomato)
POS_SIM_THRESH=0.60
POS_SIM_THRES=0.60  # Alternative spelling support

# Ngưỡng tương đồng với mẫu âm tính (not tomato)
NEG_SIM_THRESH=0.75
NEG_SIM_THRES=0.75  # Alternative spelling support

# Logging Configuration
# Levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Browser Auto-open
# Set to 'false' to disable automatic browser opening on server start
AUTO_OPEN_BROWSER=true

# Admin Authentication (HTTP Basic Auth)
# CẢNH BÁO: Đổi username/password trước khi deploy production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password-here

# Server Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=True

# File Upload Limits
MAX_CONTENT_LENGTH=16777216  # 16MB in bytes

# Session Configuration
SESSION_COOKIE_SECURE=False  # Set True in production with HTTPS
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# ==================== Payment Gateway Configuration ====================

# VNPay Payment Gateway
# Đăng ký tại: https://vnpay.vn/ hoặc https://sandbox.vnpayment.vn/
# Sandbox để test: https://sandbox.vnpayment.vn/apis/docs/thanh-toan-pay/pay.html
VNPAY_TMN_CODE=your-vnpay-tmn-code
VNPAY_SECRET_KEY=your-vnpay-secret-key
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5000/payment/vnpay/callback

# MoMo Payment Gateway  
# Đăng ký tại: https://business.momo.vn/
# Test environment: https://developers.momo.vn/
MOMO_PARTNER_CODE=your-momo-partner-code
MOMO_ACCESS_KEY=your-momo-access-key
MOMO_SECRET_KEY=your-momo-secret-key
MOMO_PAYMENT_URL=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=http://localhost:5000/payment/momo/callback
MOMO_NOTIFY_URL=http://localhost:5000/payment/momo/ipn

# Payment Notes:
# - Để test thanh toán, dùng sandbox/test environment
# - VNPay sandbox credentials có thể lấy từ docs
# - MoMo test credentials cần đăng ký tại developers.momo.vn
# - Nhớ thay đổi sang production URLs khi deploy thật
# - Return URL phải accessible từ internet (dùng ngrok nếu test local)

# ==================== Email Notification Configuration ====================

# SMTP Settings (Gmail example)
# Để sử dụng Gmail SMTP:
# 1. Bật 2-Step Verification: https://myaccount.google.com/security
# 2. Tạo App Password: https://myaccount.google.com/apppasswords
# 3. Dùng App Password làm SMTP_PASSWORD (KHÔNG dùng mật khẩu Gmail thường)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Tomato AI

# Email Notification Types:
# - Order confirmation (đặt hàng thành công)
# - Payment success/failed (thanh toán)
# - Welcome email (đăng ký tài khoản)
# - Account verification (xác thực - tương lai)
# - Password reset (đặt lại mật khẩu - tương lai)

# Các SMTP providers khác:
# Outlook: smtp.office365.com:587
# Yahoo: smtp.mail.yahoo.com:465
# SendGrid: smtp.sendgrid.net:587
# Mailgun: smtp.mailgun.org:587

# Notes:
# - Port 587: TLS (recommended)
# - Port 465: SSL
# - Port 25: Unencrypted (not recommended)
# - Test email gửi đến spam folder? Check SPF/DKIM/DMARC records
