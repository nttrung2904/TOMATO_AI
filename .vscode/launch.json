{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Flask App",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tomato/app.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "FLASK_ENV": "development",
                "FLASK_DEBUG": "0",
                "PYTHONPATH": "${workspaceFolder}",
                "PYTHONUNBUFFERED": "1",
                "PYTHONIOENCODING": "utf-8"
            },
            "cwd": "${workspaceFolder}",
            "stopOnEntry": false,
            "showReturnValue": true,
            "redirectOutput": true,
            "subProcess": false
        }
    ]
}